# 이 파일을 .env 로 복사한 뒤 값을 채워 사용하세요. (.env 는 gitignore 됨)

# ── Database ─────────────────────────────────────────
# DATABASE_HOST 는 기본값이 없어 미설정 시 부팅이 실패합니다.
DATABASE_HOST=localhost
DATABASE_PORT=5432
RAILS_MAX_THREADS=5
RAILS_MIN_THREADS=5

DEV_DATABASE_USERNAME=postgres
DEV_DATABASE_PASSWORD=
DEV_DATABASE_NAME=template_development

TEST_DATABASE_USERNAME=postgres
TEST_DATABASE_PASSWORD=
TEST_DATABASE_NAME=template_test

# ── Rails ────────────────────────────────────────────
SECRET_KEY_BASE=
RAILS_MASTER_KEY=
RAILS_LOG_LEVEL=info
ALLOWED_HOSTS=
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Auth service (외부 인증) ─────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
AUTH_SESSION_CACHE_TTL=300
AUTH_REQUEST_TIMEOUT=5

# ── Background jobs / cache ──────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Sentry ───────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── SendGrid (메일) ──────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=

# ── App ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ACTIVE_STORAGE_SERVICE=local
PORT=3000
